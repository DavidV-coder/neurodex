{
  "name": "neurodex",
  "version": "1.0.0",
  "description": "NeuroDEX — Sci-fi AI terminal. eDEX-UI interface with full multi-model AI (Claude, OpenAI, Gemini, DeepSeek, Mistral, Ollama).",
  "main": "dist/electron/main.js",
  "author": "DavidV-coder",
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "npm run build:electron-ts && cross-env NODE_ENV=development electron dist/electron/main.js",
    "build:electron-ts": "tsc -p tsconfig.electron.json",
    "build:src": "tsc -p tsconfig.src.json",
    "build:ts": "npm run build:electron-ts && npm run build:src",
    "build": "npm run build:ts && electron-builder",
    "build:mac": "npm run build:ts && electron-builder --mac",
    "build:linux": "npm run build:ts && electron-builder --linux",
    "build:win": "npm run build:ts && electron-builder --win",
    "start": "electron dist/electron/main.js",
    "lint": "eslint src electron --ext .ts,.js",
    "test": "vitest run",
    "setup": "node scripts/setup.js",
    "postinstall": "echo 'Run: npm run setup'",
    "cli": "tsx src/cli/index.ts",
    "build:cli": "tsc -p tsconfig.cli.json"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.92",
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.6.0",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "dotenv": "^16.4.7",
    "electron-store": "^10.0.0",
    "express": "^4.21.0",
    "glob": "^10.5.0",
    "highlight.js": "^11.11.0",
    "howler": "^2.2.4",
    "keytar": "^7.9.0",
    "marked": "^15.0.4",
    "micromatch": "^4.0.8",
    "mime-types": "^2.1.35",
    "node-cron": "^4.2.1",
    "node-pty": "^1.0.0",
    "openai": "^4.77.0",
    "p-limit": "^6.2.0",
    "playwright": "^1.59.1",
    "smoothie": "^1.36.1",
    "systeminformation": "^5.23.5",
    "telegram": "^2.26.22",
    "uuid": "^11.0.3",
    "ws": "^8.18.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.8.0",
    "xterm-addon-webgl": "^0.17.0-beta.36",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/marked": "^6.0.0",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.neurodex.app",
    "productName": "NeuroDEX",
    "copyright": "Copyright © 2026 NeuroDEX",
    "files": [
      "electron/**/*",
      "src/**/*",
      "ui/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "ui/assets/icons/neurodex.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "ui/assets/icons",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "ui/assets/icons/neurodex.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "bin": {
    "neurodex": "bin/neurodex.js"
  }
}
